---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "A hospitality journal reviewing boutique hotels through the lens of feeling, presence, and cultural depth." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <div class="wide-container">
        <a href="/" class="logo">
          <span class="logo-stay">Stay</span> <span class="logo-nivas">Nivas</span>
        </a>
        <nav>
          <a href="/#reviews">Reviews</a>
          <a href="/media">Media</a>
          <a href="/#subscribe" class="nav-cta">Subscribe</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p class="footer-copy">&copy; {new Date().getFullYear()} Stay Nivas</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  .site-header {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-warm-sand);
  }

  .site-header .wide-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--color-charcoal);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .logo:hover {
    opacity: 1;
  }

  .logo-stay {
    font-weight: 400;
  }

  .logo-nivas {
    font-weight: 700;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  nav a {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-slate);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1;
  }

  nav .nav-cta {
    background: var(--color-saffron);
    color: white;
    padding: 0.5rem 1.1rem;
    border-radius: 3px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    transition: opacity 0.2s;
    line-height: 1;
  }

  nav .nav-cta:hover {
    opacity: 0.9;
    color: white;
  }

  .site-footer {
    margin-top: 4rem;
    padding: 2rem 0;
    border-top: 1px solid var(--color-warm-sand);
    text-align: center;
  }

  .footer-copy {
    font-size: 0.75rem;
    color: var(--color-warm-sand);
    margin-bottom: 0;
  }
</style>
