---
interface Props {
  title: string;
  subtitle: string;
  location: string;
  date: string;
  rating: number;
  summary: string;
  image: string;
  imageAlt: string;
  slug: string;
}

const { title, subtitle, location, date, rating, summary, image, imageAlt, slug } = Astro.props;

const stars = '★'.repeat(rating) + '☆'.repeat(5 - rating);
---

<a href={`/reviews/${slug}`} class="review-card">
  <div class="review-card-image">
    <img src={image} alt={imageAlt} loading="lazy" />
  </div>
  <div class="review-card-content">
    <div class="review-card-meta">
      <span class="review-card-location">{location}</span>
      <span class="review-card-date">{date}</span>
    </div>
    <h2 class="review-card-title">{title}</h2>
    <p class="review-card-subtitle">{subtitle}</p>
    <div class="review-card-rating" aria-label={`${rating} out of 5 stars`}>{stars}</div>
    <p class="review-card-summary">{summary}</p>
    <span class="review-card-readmore">Read the review &rarr;</span>
  </div>
</a>

<style>
  .review-card {
    display: block;
    text-decoration: none;
    color: inherit;
    padding-bottom: 3rem;
    margin-bottom: 3rem;
    transition: transform 0.2s ease;
  }

  .review-card:not(:last-child) {
    border-bottom: 1px solid var(--color-warm-sand);
  }

  .review-card:hover {
    transform: translateY(-2px);
    opacity: 1;
  }

  .review-card-image {
    width: 100%;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    margin-bottom: 1.5rem;
    border-radius: 2px;
  }

  .review-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    transition: transform 0.4s ease;
  }

  .review-card:hover .review-card-image img {
    transform: scale(1.02);
  }

  .review-card-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-slate);
    margin-bottom: 0.75rem;
  }

  .review-card-title {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 500;
    margin-bottom: 0.25em;
    color: var(--color-charcoal);
  }

  .review-card-subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--color-slate);
    margin-bottom: 0.75em;
  }

  .review-card-rating {
    color: var(--color-saffron);
    font-size: 1.1rem;
    letter-spacing: 0.1em;
    margin-bottom: 0.75em;
  }

  .review-card-summary {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-slate);
    max-width: 65ch;
  }

  .review-card-readmore {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-saffron);
    letter-spacing: 0.02em;
  }
</style>
