---
import Base from '../layouts/Base.astro';
import ReviewCard from '../components/ReviewCard.astro';
---

<Base title="Stay Nivas — Where You Dwell Matters">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1 class="hero-title">
        <span class="hero-stay">Stay</span> <span class="hero-nivas">Nivas</span>
      </h1>
      <p class="hero-tagline">Where you dwell matters.</p>
    </div>
  </section>

  <!-- Founder's Note -->
  <section class="founders-note">
    <div class="container">
      <div class="note-content">
        <div class="note-letter">
          <p>
            I stopped trusting hotel reviews the day I realized they were all answering the wrong question. Thread count, pool temperature, breakfast buffet variety. Useful, sure. But not why I remember the places I remember.
          </p>
          <p>
            The hotels that stayed with me did something else. They changed the rhythm of my day. They made me notice things I normally walk past. They understood something about rest that goes deeper than a good mattress.
          </p>
          <p>
            Stay Nivas is my attempt to write about that. Not what a hotel has, but what it does to you. The reviews here are personal, sometimes imperfect, and always honest. If a place earned my attention, I'll tell you why. If it didn't, I'll tell you that too.
          </p>
          <p class="note-signature">&mdash; Yash Kothari</p>
        </div>
        <div class="note-author">
          <div class="note-author-row">
            <img src="/images/yash-headshot.jpg" alt="Yash Kothari" class="note-headshot" />
            <div class="note-author-text">
              <p class="note-author-name">Yash Kothari</p>
              <p class="note-bio">
                Indian-American founder and writer based in New York. Forbes contributor, with work published in The Wall Street Journal and The New York Times. Wharton grad, Y Combinator alum. Writes about hospitality through the lens of feeling, presence, and the Indian tradition of <em>atithi devo bhava</em>.
              </p>
              <p class="note-links">
                <a href="https://www.linkedin.com/in/kothariy/" target="_blank" rel="noopener">LinkedIn</a>
                <span class="link-sep">&middot;</span>
                <a href="/media">Media &amp; Contact</a>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="reviews" id="reviews">
    <div class="container">
      <h2 class="section-heading">Reviews</h2>

      <ReviewCard
        title="Hyatt Regency The Churchill"
        subtitle="Service that outpaces its own interiors"
        location="London, England"
        date="February 2026"
        rating={4}
        summary="The Churchill doesn't dazzle. It does something harder: it makes a family with a toddler feel completely at ease in Mayfair. Juan and Guillaume set the tone before we arrived, and the service throughout was exceptional. What holds it back is the interiors, which feel a step behind the team that works in them. A property where the people are better than the building."
        image="/images/hyatt-churchill/breakfast-festive.jpg"
        imageAlt="Family breakfast at The Churchill with festive decorations"
        slug="hyatt-regency-the-churchill-london"
      />

      <ReviewCard
        title="Andaz Peninsula Papagayo"
        subtitle="Where the jungle decides what kind of guest you'll be"
        location="Guanacaste, Costa Rica"
        date="November 2024"
        rating={5}
        summary="Five nights for a babymoon that set a new standard. The Andaz doesn't announce itself; it lets the Pacific and the dry tropical forest do that. What set it apart was the wellness program, genuinely woven into the property's identity, and a team led by Henrique, Paola, and Manolo who made hospitality feel personal rather than transactional. Even surpassed the nearby Four Seasons."
        image="/images/andaz-papagayo/beach-sunset.jpg"
        imageAlt="Sunset over the Pacific at Andaz Papagayo beach"
        slug="andaz-peninsula-papagayo"
      />

    </div>
  </section>

  <!-- Newsletter -->
  <section class="newsletter" id="subscribe">
    <div class="container">
      <div class="newsletter-inner">
        <h2 class="newsletter-heading">Stay in touch</h2>
        <p class="newsletter-copy">Join a growing community of travelers who care more about how a place feels than how it looks on paper. New reviews delivered to your inbox.</p>
        <form class="newsletter-form" action="https://formsubmit.co/kothari.s.yash@gmail.com" method="POST">
          <input type="hidden" name="_subject" value="New Stay Nivas subscriber" />
          <input type="hidden" name="_template" value="basic" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="text" name="_honey" style="display:none" />
          <input type="hidden" name="_next" value="https://staynivas.com/?subscribed=true" />
          <input type="email" name="email" placeholder="your@email.com" required class="newsletter-input" />
          <button type="submit" class="newsletter-button">Subscribe</button>
        </form>
      </div>
    </div>
  </section>

  <!-- More Reviews -->
  <section class="reviews reviews-continued">
    <div class="container">
      <ReviewCard
        title="The Oberoi, Mumbai"
        subtitle="The quiet authority of a hotel that has nothing left to prove"
        location="Mumbai, India"
        date="2024"
        rating={4}
        summary="A staycation at Nariman Point where Marine Drive becomes your morning view and the staff know your room number before you tell them. Shradha, Akshit, and Chef Sahil embodied the Oberoi way. The service and vegetarian dining are exceptional, but the physical product feels a half-step behind newer competitors. Authority earned through decades, even if the interiors haven't kept pace."
        image="/images/the-oberoi-mumbai/room-with-view.jpg"
        imageAlt="The Oberoi Mumbai room with city skyline view"
        slug="the-oberoi-mumbai"
      />

      <ReviewCard
        title="Soho House Mumbai"
        subtitle="The rooftop where Mumbai finally sits still"
        location="Mumbai, India"
        date="January 2024"
        rating={4}
        summary="A babymoon in Juhu where the members' club DNA shaped everything for the better. The rooftop and Cecconi's carry the experience, but some common spaces show wear and the food beyond the Italian restaurant is uneven. A four-star stay inside a five-star setting. Soho House's strength is atmosphere over polish, and in Mumbai that trade-off is more visible than in their European properties."
        image="/images/soho-house-mumbai/rooftop-pool.jpg"
        imageAlt="Rooftop pool at Soho House Mumbai"
        slug="soho-house-mumbai"
      />

      <ReviewCard
        title="The Beekman"
        subtitle="A lobby that remembers New York"
        location="New York, USA"
        date="2023"
        rating={5}
        summary="A staycation that cleared the high bar of being worthwhile for New Yorkers. The nine-story Victorian atrium is stunning, but it's the consistency of taste throughout, from the rooms to the restaurants to the elevators, that makes The Beekman more than a pretty lobby. Lauren, Justin, and Alex set the service tone before we even arrived."
        image="/images/the-beekman/tin-ceiling.jpg"
        imageAlt="The Beekman's stacked pressed-metal ceilings"
        slug="the-beekman-new-york"
      />

      <ReviewCard
        title="Ca' di Dio"
        subtitle="Beautiful design, but Venice isn't the place to feel squeezed"
        location="Venice, Italy"
        date="2023"
        rating={3}
        summary="The Patricia Urquiola interiors are genuinely striking and the staff, led by Christophe, were warm and attentive. But the room was on the smaller side, and the property felt optimized for occupancy rather than experience. In a city where your hotel room should be a refuge from the crowds, Ca' di Dio's sizing left us feeling like one of many."
        image="/images/ca-di-dio/room-lagoon-view.jpg"
        imageAlt="Ca' di Dio room with Venice lagoon view"
        slug="ca-di-dio-venice"
      />

      <ReviewCard
        title="Faarufushi Maldives"
        subtitle="A honeymoon that the hotel nearly ruined before it began"
        location="Raa Atoll, Maldives"
        date="December 2019"
        rating={2}
        summary="The spa was exceptional, the staff phenomenal, and the overwater villa looked exactly like the brochure. But a four-hour seaplane delay followed by management's refusal to take responsibility revealed a property where the front-line team delivers five-star service inside a three-star management structure. For a honeymoon, that gap is unforgivable."
        image="/images/faarufushi-maldives/overwater-villa-sunset.jpg"
        imageAlt="Overwater villa at Faarufushi Maldives at golden hour"
        slug="faarufushi-maldives"
      />

      <ReviewCard
        title="Sujan Rajmahal Palace"
        subtitle="A wedding night in a palace that earned its grandeur"
        location="Jaipur, India"
        date="December 2019"
        rating={5}
        summary="Our wedding night in the Maharani Suite, with its own dining room, pool, and a bed that required footstools. Butler Neeraj made every request effortless. They set up a couples massage in the Maharaja Suite because no treatment room would do. Rose petals, champagne, and the kind of hospitality that treats a celebration as sacred. We chose Rajmahal over Rambagh. No regrets."
        image="/images/sujan-rajmahal/arrival-portico.jpg"
        imageAlt="Arrival at Sujan Rajmahal Palace with vintage car"
        slug="sujan-rajmahal-jaipur"
      />
    </div>
  </section>

</Base>

<style>
  .hero {
    padding: 4rem 0 1.5rem;
    text-align: center;
    display: flex;
    justify-content: center;
  }

  .hero .container {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 8vw, 5rem);
    letter-spacing: 0.02em;
    margin-bottom: 0.1em;
  }

  .hero-stay { font-weight: 400; }
  .hero-nivas { font-weight: 700; }

  .hero-tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    color: var(--color-slate);
    max-width: none;
    margin-bottom: 0;
  }

  .founders-note {
    padding: 3rem 0 2.5rem;
    margin-bottom: 0;
  }

  .note-content {
    max-width: 600px;
    margin: 0 auto;
  }

  .note-letter {
    position: relative;
    padding-left: 1.5rem;
    border-left: 3px solid var(--color-saffron);
  }

  .note-letter p {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-style: italic;
    font-weight: 400;
    line-height: 1.9;
    color: var(--color-charcoal);
  }

  .note-signature {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-style: italic;
    font-weight: 500;
    margin-top: 1.5rem;
    margin-bottom: 0;
    color: var(--color-charcoal);
  }

  .note-author {
    margin-top: 2rem;
    padding-top: 0;
  }

  .note-author-row {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .note-headshot {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .note-author-text {
    flex: 1;
  }

  .note-author-name {
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.3em;
    line-height: 1.3;
  }

  .note-bio {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--color-slate);
    margin-bottom: 0.5em;
  }

  .note-links {
    margin-bottom: 0;
  }

  .note-links a {
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .reviews { padding: 0 0 4rem; }
  .reviews-continued { padding-top: 0; }

  .link-sep {
    margin: 0 0.5em;
    color: var(--color-warm-sand);
  }

  /* Newsletter */
  .newsletter {
    padding: 3rem 0;
    margin: 1rem 0;
  }

  .newsletter-inner {
    max-width: 480px;
    margin: 0 auto;
    text-align: center;
    border: 1px solid var(--color-warm-sand);
    border-radius: 4px;
    padding: 2.5rem 2rem;
  }

  .newsletter-heading {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 500;
    margin-bottom: 0.5em;
  }

  .newsletter-copy {
    font-size: 0.9rem;
    color: var(--color-slate);
    line-height: 1.6;
    margin-bottom: 1.5em;
  }

  .newsletter-form {
    display: flex;
    gap: 0.5rem;
    max-width: 400px;
    margin: 0 auto;
  }

  .newsletter-input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-warm-sand);
    border-radius: 3px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    background: white;
    color: var(--color-charcoal);
  }

  .newsletter-input:focus {
    outline: none;
    border-color: var(--color-saffron);
  }

  .newsletter-input::placeholder {
    color: var(--color-warm-sand);
  }

  .newsletter-button {
    padding: 0.75rem 1.5rem;
    background: var(--color-saffron);
    color: white;
    border: none;
    border-radius: 3px;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .newsletter-button:hover {
    opacity: 0.9;
  }

  @media (max-width: 480px) {
    .newsletter-form {
      flex-direction: column;
    }
  }

  .section-heading {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-slate);
    margin-bottom: 3rem;
  }
</style>
